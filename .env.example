# Blizzard API Credentials
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Database
DATABASE_URL=ecto://postgres:postgres@localhost/realm_agent_dev

# Node Service
NODE_SERVICE_URL=http://localhost:3000

# Phoenix Secret (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=supersecretkeythatisatleast64characterslong1234567890abc

# Polling Configuration
POLL_INTERVAL_SECONDS=60

# Region
WOW_REGION=us
